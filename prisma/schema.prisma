generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GuildSnapShot {
  id        Int      @id @default(autoincrement())
  guildName String
  date      DateTime @default(now())
  members   Json

  @@map("guild_snapshots")
}
